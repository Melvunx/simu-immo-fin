generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model financing_loans {
  id                      String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  financing_scenario_id   String              @db.Uuid
  loan_order              Int                 @default(1)
  label                   String?
  principal_amount        Decimal             @db.Decimal(12, 2)
  outstanding_capital     Decimal?            @db.Decimal(12, 2)
  nominal_rate            Decimal?            @default(0) @db.Decimal(8, 5)
  insurance_monthly       Decimal?            @default(0) @db.Decimal(12, 2)
  deferred_type           String?             @default("none")
  deferred_months         Int?                @default(0)
  amortization_months     Int?
  total_duration_months   Int?
  monthly_payment_phase_1 Decimal?            @db.Decimal(12, 2)
  monthly_payment_phase_2 Decimal?            @db.Decimal(12, 2)
  monthly_payment_phase_3 Decimal?            @db.Decimal(12, 2)
  phase_1_months          Int?                @default(0)
  phase_2_months          Int?                @default(0)
  phase_3_months          Int?                @default(0)
  loan_type               String?             @default("classic")
  created_at              DateTime            @default(now()) @db.Timestamptz(6)
  updated_at              DateTime            @default(now()) @db.Timestamptz(6)
  financing_scenarios     financing_scenarios @relation(fields: [financing_scenario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([financing_scenario_id], map: "idx_financing_loans_scenario_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model financing_scenarios {
  id                       String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id               String                  @db.Uuid
  label                    String
  is_default               Boolean?                @default(false)
  financing_mode           String                  @default("single_loan")
  down_payment             Decimal?                @default(0) @db.Decimal(12, 2)
  loan_amount              Decimal?                @default(0) @db.Decimal(12, 2)
  nominal_rate             Decimal?                @default(0) @db.Decimal(8, 5)
  insurance_monthly        Decimal?                @default(0) @db.Decimal(12, 2)
  duration_months          Int?
  deferred_months          Int?                    @default(0)
  bank_fees                Decimal?                @default(0) @db.Decimal(12, 2)
  guarantee_fees           Decimal?                @default(0) @db.Decimal(12, 2)
  broker_fees              Decimal?                @default(0) @db.Decimal(12, 2)
  monthly_payment          Decimal?                @db.Decimal(12, 2)
  annual_debt_service      Decimal?                @db.Decimal(12, 2)
  total_credit_cost        Decimal?                @db.Decimal(12, 2)
  weighted_average_rate    Decimal?                @db.Decimal(8, 5)
  smoothed_monthly_payment Decimal?                @db.Decimal(12, 2)
  notes                    String?
  created_at               DateTime                @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                @default(now()) @db.Timestamptz(6)
  financing_loans          financing_loans[]
  projects                 projects                @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  negotiation_scenarios    negotiation_scenarios[]
  operating_scenarios      operating_scenarios[]

  @@index([project_id], map: "idx_financing_scenarios_project_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model market_comparables {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id      String    @db.Uuid
  comparable_type String
  source          String
  source_url      String?
  address         String?
  city            String?
  zipcode         String?
  district        String?
  property_type   String?
  rooms           Decimal?  @db.Decimal(4, 1)
  area_m2         Decimal?  @db.Decimal(10, 2)
  floor           String?
  condition       String?
  dpe             String?
  price           Decimal?  @db.Decimal(12, 2)
  rent_monthly    Decimal?  @db.Decimal(12, 2)
  charges_monthly Decimal?  @db.Decimal(12, 2)
  euro_per_m2     Decimal?  @db.Decimal(12, 2)
  comparable_date DateTime? @db.Date
  notes           String?
  distance_km     Decimal?  @db.Decimal(10, 2)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  projects        projects  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id], map: "idx_market_comparables_project_id")
  @@index([comparable_type], map: "idx_market_comparables_type")
}

model market_summaries {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id           String   @unique @db.Uuid
  dvf_median_eur_m2    Decimal? @db.Decimal(12, 2)
  dvf_mean_eur_m2      Decimal? @db.Decimal(12, 2)
  dvf_p25_eur_m2       Decimal? @db.Decimal(12, 2)
  dvf_p75_eur_m2       Decimal? @db.Decimal(12, 2)
  dvf_sample_size      Int?
  dvf_target_price     Decimal? @db.Decimal(12, 2)
  market_rent_median   Decimal? @db.Decimal(12, 2)
  market_rent_low      Decimal? @db.Decimal(12, 2)
  market_rent_high     Decimal? @db.Decimal(12, 2)
  market_rent_eur_m2   Decimal? @db.Decimal(12, 2)
  rental_tension_label String?
  rental_tension_score Decimal? @db.Decimal(8, 4)
  price_gap_vs_market  Decimal? @db.Decimal(8, 4)
  rent_gap_vs_market   Decimal? @db.Decimal(8, 4)
  summary              String?
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @db.Timestamptz(6)
  projects             projects @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id], map: "idx_market_summaries_project_id")
}

